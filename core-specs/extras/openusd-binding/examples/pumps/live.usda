#usda 1.0
(
    upAxis = "Y"
    doc = "OPC UA -> OpenUSD live bindings (demo)"
)

over "Plant"
{
    over "Pumps"
    {
        over "P101"
        {
            double xformOp:rotateZ = 87.0000
            token visibility = "inherited"
        }
    }
}

over "Plant"
{
    over "Pumps"
    {
        over "P101"
        {
            over "Body"
            {
                color3f primvars:displayColor = (0.6562, 0.0000, 0.3438)
            }
        }
    }
}
