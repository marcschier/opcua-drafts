{
  "domain": "Pumps",
  "appliesToType": "PumpType",
  "baseModelNamespaceUri": "http://opcfoundation.org/UA/Pumps/",
  "exampleNamespaceUri": "http://opcfoundation.org/UA/PubSub/Examples/Pumps/",
  "instanceName": "ExamplePump",
  "summary": "Pumps expose rich operational telemetry (flow, head, pressure, power, temperatures, efficiencies, rotor loads) plus identity and maintenance data, so most industrial scenarios map cleanly onto the pump measurement model.",
  "companionSpec": { "name": "OPC UA for Pumps and Vacuum Pumps", "ref": "https://reference.opcfoundation.org/Pumps/v100/docs/" },
  "instanceModel": {
    "note": "The theoretical instance mirrors the official Pumps `instanceexample.xml` (an `ExamplePump : PumpType` with `Operational/Measurements`, `Identification`, `Supervision*`, `Maintenance` and a `<Drive>`); the bound BrowsePaths resolve against exactly that structure.",
    "ref": "https://github.com/OPCFoundation/UA-Nodeset/blob/latest/Pumps/instanceexample.xml",
    "refName": "Pumps/instanceexample.xml"
  },
  "configurationVersion": { "majorVersion": 1, "minorVersion": 0 },
  "companionSpecificationUri": "http://opcfoundation.org/UA/Pumps/",
  "modelNamespaceUris": ["http://opcfoundation.org/UA/Pumps/"],
  "groupName": "Pumps",
  "baseNodeSets": [
    "Opc.Ua.Pumps.NodeSet2.xml",
    "Opc.Ua.Di.NodeSet2.xml",
    "Opc.Ua.Machinery.NodeSet2.xml"
  ],
  "requiredModels": [
    { "uri": "http://opcfoundation.org/UA/Pumps/" },
    { "uri": "http://opcfoundation.org/UA/DI/" },
    { "uri": "http://opcfoundation.org/UA/Machinery/" }
  ],
  "scenarioBindings": [
    {
      "name": "Observability",
      "scenarioUri": "http://opcfoundation.org/UA/PubSub/Scenarios/Observability",
      "direction": "Publisher",
      "boundItems": [
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "1/min", "browsePath": "/Operational/Measurements/Speed", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "m3/s", "browsePath": "/Operational/Measurements/Throughput", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "kg/s", "browsePath": "/Operational/Measurements/MassFlow", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "Pa", "browsePath": "/Operational/Measurements/ProcessPressure", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "Pa", "browsePath": "/Operational/Measurements/DifferentialPressure", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "m", "browsePath": "/Operational/Measurements/PumpTotalHead", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "W", "browsePath": "/Operational/Measurements/PumpPowerInput", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "Cel", "browsePath": "/Operational/Measurements/FluidTemperature", "samplingIntervalHint": 2000 },
        { "kind": "Telemetry", "metricInstrumentType": "Histogram", "unit": "Cel", "explicitBucketBoundaries": [40, 60, 80, 100, 120], "browsePath": "/Operational/Measurements/BearingTemperature", "samplingIntervalHint": 2000 },
        { "kind": "Telemetry", "metricInstrumentType": "Gauge", "unit": "Cel", "browsePath": "/Operational/Measurements/PumpTemperature", "samplingIntervalHint": 2000 },
        { "kind": "Counter", "metricInstrumentType": "Counter", "metricTemporality": "Cumulative", "monotonic": true, "browsePath": "/Operational/Measurements/NumberOfStarts", "samplingIntervalHint": 10000 },
        { "kind": "Dimension", "fieldName": "Manufacturer", "browsePath": "/Identification/Manufacturer" },
        { "kind": "Dimension", "fieldName": "SerialNumber", "browsePath": "/Identification/SerialNumber" },
        { "kind": "Dimension", "fieldName": "service.name", "dimensionConstantValue": "pump-observability" }
      ]
    },
    {
      "name": "EnergyAndLoadManagement",
      "scenarioUri": "http://opcfoundation.org/UA/PubSub/Scenarios/EnergyAndLoadManagement",
      "direction": "Publisher",
      "boundItems": [
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/PumpPowerInput", "samplingIntervalHint": 1000 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/PumpPowerOutput", "samplingIntervalHint": 1000 },
        { "kind": "Metric", "browsePath": "/Operational/Measurements/OverallEfficiency", "samplingIntervalHint": 5000 },
        { "kind": "Metric", "browsePath": "/Operational/Measurements/PumpEfficiency", "samplingIntervalHint": 5000 },
        { "kind": "Metric", "browsePath": "/Operational/Measurements/HydraulicEfficiency", "samplingIntervalHint": 5000 }
      ]
    },
    {
      "name": "PredictiveMaintenance",
      "scenarioUri": "http://opcfoundation.org/UA/PubSub/Scenarios/PredictiveMaintenance",
      "direction": "Publisher",
      "boundItems": [
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/BearingTemperature", "samplingIntervalHint": 5000 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/AxialLoadOfPumpRotor", "samplingIntervalHint": 5000 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/RadialLoadOfPumpRotor", "samplingIntervalHint": 5000 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/LubricatingOilPressure", "samplingIntervalHint": 5000 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/AxialRotorPosition", "samplingIntervalHint": 5000 },
        { "kind": "Counter", "browsePath": "/Operational/Measurements/NumberOfStarts", "samplingIntervalHint": 10000 }
      ]
    },
    {
      "name": "AnomalyDetection",
      "scenarioUri": "http://opcfoundation.org/UA/PubSub/Scenarios/AnomalyDetection",
      "direction": "Publisher",
      "boundItems": [
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/SoundPower", "samplingIntervalHint": 500 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/SoundPressureLevel", "samplingIntervalHint": 500 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/DifferentialPressure", "samplingIntervalHint": 500 },
        { "kind": "Telemetry", "browsePath": "/Operational/Measurements/BearingTemperature", "samplingIntervalHint": 500 }
      ]
    },
    {
      "name": "FleetAndCompliance",
      "scenarioUri": "http://opcfoundation.org/UA/PubSub/Scenarios/FleetAndCompliance",
      "direction": "Publisher",
      "baseDataSetClassIds": ["cb5100f1-96f5-5999-a09f-97b71bb044be"],
      "boundItems": [
        { "kind": "Identification", "browsePath": "/Identification/AssetId" },
        { "kind": "Identification", "browsePath": "/Identification/Location" }
      ]
    },
    {
      "name": "AlarmAndEventDistribution",
      "scenarioUri": "http://opcfoundation.org/UA/PubSub/Scenarios/AlarmAndEventDistribution",
      "direction": "Publisher",
      "contentKind": "Events",
      "eventSourcePath": "/",
      "eventType": "BaseEventType",
      "logTemplate": "{SourceName}: {Message} (severity {Severity})",
      "logSeverityFieldName": "Severity",
      "logBodyFieldName": "Message",
      "logTimestampFieldName": "Time",
      "boundItems": [
        { "fieldName": "EventId", "kind": "Event", "browsePath": "/EventId" },
        { "fieldName": "EventType", "kind": "Event", "browsePath": "/EventType" },
        { "fieldName": "SourceName", "kind": "Event", "browsePath": "/SourceName" },
        { "fieldName": "Time", "kind": "Event", "browsePath": "/Time" },
        { "fieldName": "Severity", "kind": "Event", "browsePath": "/Severity" },
        { "fieldName": "Message", "kind": "Event", "browsePath": "/Message" },
        { "fieldName": "service.name", "kind": "Dimension", "dimensionConstantValue": "pump-observability" }
      ]
    }
  ]
}
